{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MAM_Session_MAP",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "session_map_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "actor_id": {
      "type": "string"
    },
    "merkle_root": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "signature": {
      "type": "string"
    },
    "signing_key_id": {
      "type": "string"
    },
    "leaf_records": {
      "type": "array"
    }
  },
  "required": [
    "version",
    "session_id",
    "agent_id",
    "merkle_root",
    "signature",
    "leaf_records"
  ]
}
